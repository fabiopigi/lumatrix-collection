{
  "schema": "lumatrix-fonts-v1",
  "description": "Pixel fonts for LUMATRIX and similar LED-matrix displays. Two bitmap fonts at different sizes.",
  "format": {
    "encoding": "Each glyph is an array of strings, one string per row, ordered top-to-bottom. Each character represents one pixel: 'X' = pixel ON, '.' = pixel OFF. Every row has the same length (= font width). Every glyph has the same number of rows (= font height).",
    "indexing": "row 0 is the topmost row of the glyph; column 0 is the leftmost. To render a glyph at position (x0, y0), light pixel (x0 + col, y0 + row) for every 'X' encountered.",
    "kerning_advice": "When rendering a text string, advance the cursor by (font_width + 1) per character to leave a 1-pixel gap between glyphs. The trailing blank row in the 5x8 font already provides vertical line spacing."
  },
  "usage_examples": {
    "python_render": "def render(text, font, x0, y0, set_pixel):\n    cursor_x = x0\n    for ch in text:\n        glyph = font['glyphs'].get(ch) or font['glyphs'].get(ch.upper()) or font['glyphs'][' ']\n        for dy, row in enumerate(glyph):\n            for dx, p in enumerate(row):\n                if p == 'X':\n                    set_pixel(cursor_x + dx, y0 + dy)\n        cursor_x += font['width'] + 1",
    "javascript_render": "function render(text, font, x0, y0, setPixel) {\n  let cx = x0;\n  for (const ch of text) {\n    const glyph = font.glyphs[ch] || font.glyphs[ch.toUpperCase()] || font.glyphs[' '];\n    for (let dy = 0; dy < glyph.length; dy++) {\n      for (let dx = 0; dx < glyph[dy].length; dx++) {\n        if (glyph[dy][dx] === 'X') setPixel(cx + dx, y0 + dy);\n      }\n    }\n    cx += font.width + 1;\n  }\n}",
    "fallback_chain": "When rendering, try the exact character first, then its uppercase form, then the space glyph. This way the 3x5 font (which has only uppercase + digits + a few punctuation) still works when given lowercase input."
  },
