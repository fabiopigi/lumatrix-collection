{
  "schema": "lumenlab-fonts-v1",
  "description": "Pixel fonts for LumenLab and similar LED-matrix displays. Fixed-width fonts at small sizes (3x5, 5x8) and a proportional pixel font (7x9).",
  "format": {
    "encoding": "Each glyph is an array of strings, one string per row, ordered top-to-bottom. Each character represents one pixel: 'X' = pixel ON, '.' = pixel OFF. Within a glyph, every row has the same length (the glyph's width). For fixed-width fonts (3x5, 5x8) all glyphs share the same width, given as the font's top-level `width`. Proportional fonts (7x9) set `proportional: true` and omit the top-level `width` — each glyph's width is determined by the length of its rows.",
    "indexing": "row 0 is the topmost row of the glyph; column 0 is the leftmost. To render a glyph at position (x0, y0), light pixel (x0 + col, y0 + row) for every 'X' encountered.",
    "kerning_advice": "For fixed-width fonts (3x5, 5x8), advance the cursor by (font.width + 1) per character to leave a 1-pixel gap. The trailing blank row in 5x8 provides vertical line spacing. For proportional fonts (7x9), advance by the glyph's own width — right-bearing is baked into each glyph, so no extra gap is needed."
  },
  "usage_examples": {
    "python_render": "def render(text, font, x0, y0, set_pixel):\n    cursor_x = x0\n    gap = 0 if font.get('proportional') else 1\n    for ch in text:\n        glyph = font['glyphs'].get(ch) or font['glyphs'].get(ch.upper()) or font['glyphs'][' ']\n        for dy, row in enumerate(glyph):\n            for dx, p in enumerate(row):\n                if p == 'X':\n                    set_pixel(cursor_x + dx, y0 + dy)\n        cursor_x += len(glyph[0]) + gap",
    "javascript_render": "function render(text, font, x0, y0, setPixel) {\n  let cx = x0;\n  const gap = font.proportional ? 0 : 1;\n  for (const ch of text) {\n    const glyph = font.glyphs[ch] || font.glyphs[ch.toUpperCase()] || font.glyphs[' '];\n    for (let dy = 0; dy < glyph.length; dy++) {\n      for (let dx = 0; dx < glyph[dy].length; dx++) {\n        if (glyph[dy][dx] === 'X') setPixel(cx + dx, y0 + dy);\n      }\n    }\n    cx += glyph[0].length + gap;\n  }\n}",
    "fallback_chain": "When rendering, try the exact character first, then its uppercase form, then the space glyph. This way the 3x5 font (which has only uppercase + digits + a few punctuation) still works when given lowercase input."
  },
